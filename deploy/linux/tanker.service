[Unit]
Description=Tanker FastAPI service
After=network.target

[Service]
Type=simple
User=tanker
Group=www-data
WorkingDirectory=/opt/tanker/current
EnvironmentFile=/etc/tanker.env
ExecStart=/opt/tanker/current/.venv/bin/gunicorn app.main:app -k uvicorn.workers.UvicornWorker -w 2 -b 127.0.0.1:8000
Restart=always
RestartSec=3
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
